{
  "mode": "interactive",
  "granularity": "standard",
  "parallelization": false,
  "commit_docs": true,
  "model_profile": "inherit",
  "graphify": { 
    "enabled": true 
  },
  "git": {
    "branching_strategy": "phase",
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}" 
  },  
  "workflow": {
    "research": true,
    "plan_check": false,
    "verifier": false,
    "nyquist_validation": true,
    "auto_advance": true
  },
  "ship": {
    "pr_body_sections": []
  }
}